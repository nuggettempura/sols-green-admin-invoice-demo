# Copy this file to .env.local and fill in the values.
# The demo needs NO third-party credentials: emails are captured by Ethereal
# (a test inbox with per-message preview URLs — nothing is really delivered),
# and payment links are placeholders.

# Firebase client config (Firebase Console → Project Settings → Your apps)
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_AUTH_DOMAIN=
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_STORAGE_BUCKET=
NEXT_PUBLIC_MESSAGING_SENDER_ID=
NEXT_PUBLIC_APP_ID=

# Firebase Admin SDK (Project Settings → Service accounts → Generate new
# private key). Paste the entire JSON as a single line.
SERVICE_ACCOUNT=

# Shared secret for the scheduled cron trigger and chunk self-invocations.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# App base URL (payment-placeholder links, chunk self-trigger origin)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Safety cap: refuse runs targeting more recipients than this (default 100)
# MAX_RECIPIENTS_PER_RUN=100

# OPTIONAL — real email delivery. Leave unset to use Ethereal capture mode.
# Point at any SMTP provider (Resend, SES, Gmail app password, ...).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SOLS Energy <no-reply@example.com>"

# Local development against the Firebase emulator (never set these in Vercel)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080
NEXT_PUBLIC_USE_EMULATOR=true
